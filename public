:root {
  --bg: #08111f;
  --panel: rgba(10, 21, 37, 0.76);
  --panel-strong: #0f1d31;
  --border: rgba(136, 184, 255, 0.18);
  --text: #eef4ff;
  --muted: #9db0cd;
  --accent: #4fd1b5;
  --accent-2: #7dd3fc;
  --warn: #f59e0b;
  --danger: #fb7185;
  --success: #34d399;
  --shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  --radius: 22px;
  --radius-sm: 14px;
  --max: 1200px;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
  font-family: "Segoe UI", "SF Pro Display", "Helvetica Neue", sans-serif;
  background:
    radial-gradient(circle at top left, rgba(79, 209, 181, 0.12), transparent 25%),
    radial-gradient(circle at top right, rgba(125, 211, 252, 0.12), transparent 35%),
    linear-gradient(180deg, #07111d 0%, #091626 52%, #07111d 100%);
  color: var(--text);
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  max-width: 100%;
}

.page-shell {
  padding: 24px;
}

.site-header,
.section,
.hero,
.content-grid,
.panel {
  width: min(var(--max), 100%);
  margin: 0 auto;
}

.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 18px 22px;
  background: rgba(8, 17, 31, 0.58);
  border: 1px solid var(--border);
  border-radius: 999px;
  position: sticky;
  top: 18px;
  z-index: 10;
  backdrop-filter: blur(18px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 14px;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.brand-mark {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
  display: grid;
  place-items: center;
  color: #08111f;
  font-weight: 800;
}

.nav {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}

.nav a,
.text-link {
  color: var(--muted);
}

.nav a:hover,
.text-link:hover {
  color: var(--text);
}

.hero {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 24px;
  padding-top: 44px;
}

.hero-card,
.panel,
.metric-card,
.list-card,
.table-card,
.banner,
.step-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
}

.hero-card {
  padding: 38px;
}

.eyebrow,
.pill,
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 13px;
  font-weight: 600;
}

.eyebrow,
.pill {
  color: var(--accent);
  background: rgba(79, 209, 181, 0.1);
  border: 1px solid rgba(79, 209, 181, 0.22);
}

.badge {
  color: #08111f;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
}

h1,
h2,
h3,
h4,
p {
  margin: 0;
}

h1 {
  font-size: clamp(2.5rem, 4vw, 4.6rem);
  line-height: 0.95;
  margin-top: 18px;
}

h2 {
  font-size: clamp(1.7rem, 3vw, 2.6rem);
  margin-bottom: 10px;
}

h3 {
  font-size: 1.15rem;
}

.subhead {
  color: var(--muted);
  line-height: 1.7;
  max-width: 58ch;
  margin-top: 18px;
}

.hero-actions,
.stack-row,
.filter-row,
.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
}

.hero-actions {
  margin-top: 30px;
}

.button,
button {
  appearance: none;
  border: 0;
  cursor: pointer;
  color: #07111d;
  font-weight: 700;
  border-radius: 999px;
  padding: 14px 20px;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
}

.button.secondary,
button.secondary {
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border);
}

.hero-stats,
.stats-grid,
.cards-grid,
.content-grid,
.filters-layout,
.dashboard-grid,
.steps-grid,
.wallet-grid,
.order-grid,
.detail-grid {
  display: grid;
  gap: 18px;
}

.hero-stats {
  grid-template-columns: repeat(3, 1fr);
  margin-top: 34px;
}

.metric-card {
  padding: 20px;
}

.metric-label {
  color: var(--muted);
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.metric-value {
  font-size: 1.85rem;
  margin-top: 8px;
}

.metric-note {
  color: var(--muted);
  margin-top: 8px;
  line-height: 1.6;
}

.section {
  margin-top: 34px;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 18px;
  margin-bottom: 20px;
}

.cards-grid {
  grid-template-columns: repeat(3, 1fr);
}

.steps-grid {
  grid-template-columns: repeat(4, 1fr);
}

.step-card,
.list-card,
.table-card {
  padding: 22px;
}

.kicker {
  color: var(--accent-2);
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.09em;
}

.list-card p,
.step-card p,
.table-card p,
.panel p {
  color: var(--muted);
  line-height: 1.7;
}

.table-like {
  width: 100%;
  border-collapse: collapse;
  margin-top: 16px;
}

.table-like th,
.table-like td {
  border-bottom: 1px solid rgba(157, 176, 205, 0.12);
  padding: 14px 0;
  text-align: left;
  font-size: 14px;
}

.table-like th {
  color: var(--muted);
  font-weight: 600;
}

.banner {
  padding: 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.filters-layout {
  grid-template-columns: 300px 1fr;
}

.panel {
  padding: 24px;
}

.filter-group {
  display: grid;
  gap: 10px;
  margin-top: 16px;
}

label {
  display: grid;
  gap: 8px;
  color: var(--muted);
  font-size: 14px;
}

input,
select,
textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(157, 176, 205, 0.15);
  color: var(--text);
  border-radius: 14px;
  padding: 12px 14px;
  font: inherit;
}

textarea {
  min-height: 120px;
  resize: vertical;
}

.result-list {
  display: grid;
  gap: 16px;
}

.result-card {
  padding: 20px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, rgba(15, 29, 49, 0.88), rgba(8, 17, 31, 0.88));
}

.result-top,
.result-meta,
.site-meta,
.order-top {
  display: flex;
  justify-content: space-between;
  align-items: start;
  gap: 16px;
  flex-wrap: wrap;
}

.result-meta,
.site-meta {
  margin-top: 14px;
  color: var(--muted);
  font-size: 14px;
}

.tag-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 14px;
}

.tag {
  border-radius: 999px;
  padding: 7px 11px;
  font-size: 12px;
  background: rgba(125, 211, 252, 0.12);
  border: 1px solid rgba(125, 211, 252, 0.2);
  color: var(--accent-2);
}

.reason-list,
.timeline,
.detail-list {
  margin: 14px 0 0;
  padding-left: 18px;
  color: var(--muted);
  line-height: 1.8;
}

.timeline li::marker,
.reason-list li::marker,
.detail-list li::marker {
  color: var(--accent);
}

.wallet-grid {
  grid-template-columns: 1.05fr 0.95fr;
}

.wallet-balance {
  font-size: clamp(2rem, 3.3vw, 3.6rem);
  margin-top: 14px;
}

.mini-stat {
  display: grid;
  gap: 6px;
  padding: 16px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(157, 176, 205, 0.12);
}

.dashboard-grid,
.order-grid,
.detail-grid {
  grid-template-columns: repeat(2, 1fr);
}

.status {
  padding: 7px 12px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
}

.status.success {
  color: #02150f;
  background: var(--success);
}

.status.pending {
  color: #1a1103;
  background: var(--warn);
}

.status.alert {
  color: #22040c;
  background: var(--danger);
}

.footer {
  width: min(var(--max), 100%);
  margin: 34px auto 0;
  padding: 28px 0 10px;
  color: var(--muted);
  display: flex;
  justify-content: space-between;
  gap: 18px;
  flex-wrap: wrap;
}

.auth-panel {
  max-width: 620px;
}

.form-grid {
  display: grid;
  gap: 14px;
  margin-top: 18px;
}

.notice {
  width: min(var(--max), 100%);
  margin: 0 auto;
  padding: 16px 18px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.04);
}

.notice.success {
  border-color: rgba(52, 211, 153, 0.3);
  background: rgba(52, 211, 153, 0.12);
}

.notice.danger {
  border-color: rgba(251, 113, 133, 0.3);
  background: rgba(251, 113, 133, 0.12);
}

.inline-form {
  display: grid;
  grid-template-columns: 1.2fr 180px 120px;
  gap: 12px;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(157, 176, 205, 0.12);
}

.inline-form:last-child {
  border-bottom: 0;
}

strong {
  font-weight: 700;
}

@media (max-width: 720px) {
  .inline-form {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 1024px) {
  .hero,
  .wallet-grid,
  .filters-layout,
  .dashboard-grid,
  .order-grid,
  .detail-grid {
    grid-template-columns: 1fr;
  }

  .cards-grid,
  .steps-grid,
  .hero-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 720px) {
  .page-shell {
    padding: 16px;
  }

  .site-header {
    border-radius: 24px;
    align-items: start;
  }

  .hero-card,
  .panel,
  .banner {
    padding: 22px;
  }

  .cards-grid,
  .steps-grid,
  .hero-stats {
    grid-template-columns: 1fr;
  }
}

